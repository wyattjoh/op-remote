{
  "name": "@wyattjoh/op-remote",
  "version": "0.5.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/wyattjoh/op-remote.git"
  },
  "bin": {
    "op-remote": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build src/cli.ts --target=node --outdir=dist --format=esm",
    "check": "bun run lint && bun run fmt:check && bun run typecheck && bun run build && bun test",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
