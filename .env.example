# ── Telegram ──────────────────────────────────────────────────────────────────
# Required: Telegram bot token (store in 1Password, reference via .env.tpl)
REMOTE_OP_TELEGRAM_BOT_TOKEN=

# Required: Telegram chat ID to send approval requests to
REMOTE_OP_TELEGRAM_CHAT_ID=

# Optional: Comma-separated Telegram user IDs allowed to approve (all users if unset)
# REMOTE_OP_TELEGRAM_APPROVER_IDS=

# Optional: Approval timeout in seconds (default: 120)
# REMOTE_OP_TIMEOUT=120
